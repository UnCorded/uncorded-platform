# UnCorded Central API — environment configuration
#
# Copy to `.env` and fill in real values for local development. In production,
# set these via the deploy environment, not a checked-in file. Variables marked
# REQUIRED below must be set in production; missing them either disables a
# feature with a runtime warning (dev-friendly) or refuses to mint signed
# tokens (SIGNING_KEY_SECRET).

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# HTTP port the API listens on. Defaults to 4000.
PORT=4000

# Standard Node mode flag. Set to "development" or "test" to enable the
# permissive dev paths (verification-URL stdout fallback when RESEND_API_KEY
# is missing, CAPTCHA bypass when TURNSTILE_SECRET_KEY is missing, etc.).
# Any other value — including unset — is treated as production and forces
# every required secret to be set at boot. This is the secure default:
# misconfiguration fails closed instead of silently leaking tokens via dev
# fallbacks.
NODE_ENV=development

# Public origin where this API is reachable (used for password-reset links,
# email verification redirects, etc.). REQUIRED in production. In dev, falls
# back to http://localhost:4000.
APP_BASE_URL=http://localhost:4000

# Where the website redirects after a successful login. REQUIRED in production.
# In dev, falls back to http://localhost:5174 (the Vite dev server).
POST_LOGIN_REDIRECT=http://localhost:5174

# ---------------------------------------------------------------------------
# Postgres (server identity, accounts, sessions, plugin metadata)
# ---------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=5432
DB_NAME=uncorded_central
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Cryptographic secrets
# ---------------------------------------------------------------------------

# Master secret used to derive the symmetric key that encrypts the active
# Ed25519 signing key in Postgres. REQUIRED in production — without it, the
# signing-key bootstrap is skipped and the API cannot mint server tokens.
# Must be at least 32 bytes; rotate by re-deploying with a new value AFTER
# re-encrypting the stored signing key with the new derivation.
SIGNING_KEY_SECRET=

# HMAC key protecting the OAuth `state` parameter (replay/forgery defense).
# If unset, a process-local random key is generated, which means restart
# invalidates all in-flight OAuth flows. Set in production for stable behavior
# across rolling restarts.
OAUTH_STATE_SECRET=

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------

# Resend API key. When unset, verification/notification emails are logged to
# stdout instead of being delivered — useful for local dev, never for prod.
RESEND_API_KEY=

# From-address used on outbound mail. Defaults to noreply@uncorded.app.
RESEND_FROM_EMAIL=noreply@uncorded.app

# ---------------------------------------------------------------------------
# CAPTCHA (Cloudflare Turnstile)
# ---------------------------------------------------------------------------

# Turnstile secret-key counterpart of the website's VITE_TURNSTILE_SITE_KEY.
# When unset, CAPTCHA validation is bypassed (dev mode). REQUIRED in
# production — without it, registration and login lose their bot defense.
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Admin allowlist
# ---------------------------------------------------------------------------

# Comma-separated list of email addresses whose accounts are granted admin
# privileges (plugin publishing, marketplace moderation). The list is consulted
# at request time, so adding/removing emails takes effect on the next request.
ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# OAuth providers
# ---------------------------------------------------------------------------

# Where the OAuth callback redirects land. Defaults to http://localhost:4000.
# In production, set to the public APP_BASE_URL.
OAUTH_REDIRECT_BASE=http://localhost:4000

# Google — register an OAuth client at console.cloud.google.com and add the
# callback URL <OAUTH_REDIRECT_BASE>/v1/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord — register at discord.com/developers/applications and add the
# callback URL <OAUTH_REDIRECT_BASE>/v1/auth/discord/callback.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitHub — register an OAuth App at github.com/settings/developers and add
# the callback URL <OAUTH_REDIRECT_BASE>/v1/auth/github/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Object storage (Cloudflare R2)
# ---------------------------------------------------------------------------
#
# When any R2 var is missing the upload endpoints return 503. Required for
# avatar uploads, plugin bundle storage, and any user-supplied media in
# production.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Public CDN URL fronting the R2 bucket — files written via signed-PUT are
# served from here. Without it, signed-GET fallbacks are used and reads are
# slower + cost more.
R2_PUBLIC_URL=
