# Cloudflare Turnstile site key (public — safe to commit to repo as .env.example)
# Find it at: Cloudflare Dashboard → Turnstile → your widget → Site Key
VITE_TURNSTILE_SITE_KEY=

# Override Central URL for production builds (dev uses the Vite proxy to localhost:4000)
# VITE_CENTRAL_URL=https://central.uncorded.app
