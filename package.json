{
  "name": "uncorded-platform",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bun run scripts/typecheck-all.cjs",
    "test": "bun test",
    "test:integration": "bun test runtime/src/text-channels.test.ts",
    "test:central": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/uncorded_central_test bun test apps/central",
    "test:central:db": "docker compose -f docker/docker-compose.test.yml up -d --wait",
    "test:central:db:stop": "docker compose -f docker/docker-compose.test.yml down -v",
    "test:boot": "bun test --timeout 15000 --path-ignore-patterns='**/text-channels.test.ts' apps/central/src/index.boot.test.ts",
    "lint": "bunx oxlint .",
    "check:cosign-sync": "node scripts/check-cosign-pubkey-sync.cjs",
    "build:website": "cd apps/website && bun run build",
    "serve:website": "bun run scripts/serve-website.ts",
    "docker:rebuild-runtime": "bun run scripts/rebuild-runtime-image.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxlint": "^0.13.0",
    "typescript": "^5.4.0",
    "zod": "^4.3.6"
  }
}
